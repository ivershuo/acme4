# ACME4 ignore rules
# Certificates and account keys (never commit these!)
certs/
accounts/
*.crt
*.key

# Local config files with sensitive info
config.yaml
config.email-example.yaml

# Test files and scripts (may contain sensitive data)
test_email.go
test_*.yaml

# Email notification config with real API keys
*email*.yaml
*resend*.yaml

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

acme4
